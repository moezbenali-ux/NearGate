# ============================================================
#  NearGate — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs réelles.
#  NE JAMAIS versionner .env (déjà dans .gitignore).
# ============================================================

# Clé API (non utilisée actuellement, réservée pour usage futur)
API_KEY=

# MQTT — adresse du broker Mosquitto (sur le Raspberry Pi)
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=neargate
MQTT_PASSWORD=

# JWT — clé secrète pour signer les tokens d'authentification
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
# OBLIGATOIRE — le serveur refusera de démarrer sans cette valeur.
JWT_SECRET=

# Base de données SQLite
DB_PATH=neargate.db

# Identifiant client unique (pour la synchronisation multi-tenant)
CLIENT_ID=

# Synchronisation Scaleway (laisser vide tant que le serveur central n'est pas prêt)
SCALEWAY_API_URL=
SCALEWAY_API_KEY=

# Email — envoi via Resend.com (SMTP)
# 1. Créer un compte sur resend.com
# 2. Ajouter le domaine neargate.fr et copier les enregistrements DNS dans Cloudflare
# 3. Créer une clé API dans Resend → API Keys
# SMTP_USER doit toujours être "resend" (littéralement)
# SMTP_PASSWORD = la clé API Resend (commence par re_)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Adresse expéditeur — doit appartenir au domaine vérifié sur Resend
SMTP_FROM=noreply@neargate.fr
BASE_URL=https://app.neargate.fr
