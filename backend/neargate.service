[Unit]
Description=NearGate Backend API
After=network.target mosquitto.service

[Service]
User=admin
WorkingDirectory=/home/admin/NearGate/backend
ExecStartPre=/usr/sbin/rfkill unblock bluetooth
ExecStart=/home/admin/NearGate/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
